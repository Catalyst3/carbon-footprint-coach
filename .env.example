# Copy to .env and fill in. NEVER commit the real .env.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides (sensible defaults are baked in).
# ECOLENS_MODEL=claude-opus-4-8
# ECOLENS_MAX_TOKENS=1024
# ECOLENS_MAX_HISTORY_TURNS=12
# ECOLENS_MAX_MESSAGE_CHARS=2000

# Rate limiting (per client IP) — protects your API key on a public URL.
# ECOLENS_RATE_BURST=10        # bucket capacity (max burst)
# ECOLENS_RATE_PER_MIN=20      # sustained requests/min refill
